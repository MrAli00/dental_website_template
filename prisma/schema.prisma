generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  service   String
  message   String?
  status    String   @default("nuovo") // nuovo, contattato, perso, convertito
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}